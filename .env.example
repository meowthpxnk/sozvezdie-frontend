# Copy to .env.local for local dev, or set before `docker compose build`.
# NEXT_PUBLIC_* are embedded into the client bundle at build time.

# Backend API (must be reachable from the browser)
NEXT_PUBLIC_API_URL=http://localhost:8000

# MinIO / media server (must be reachable from the browser)
NEXT_PUBLIC_MEDIA_URL=http://localhost:4003

# Optional: override full bucket URL (default: ${NEXT_PUBLIC_MEDIA_URL}/images-bucket)
# NEXT_PUBLIC_MEDIA_BUCKET_URL=http://localhost:4003/images-bucket
